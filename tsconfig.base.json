{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@patioer/db": ["packages/db/src/index.ts"],
      "@patioer/shared": ["packages/shared/src/index.ts"],
      "@patioer/harness": ["packages/harness/src/index.ts"],
      "@patioer/agent-runtime": ["packages/agent-runtime/src/index.ts"],
      "@patioer/market": ["packages/market/src/index.ts"],
      "@patioer/devos-bridge": ["packages/devos-bridge/src/index.ts"],
      "@patioer/dataos": ["packages/dataos/src/index.ts"],
      "@patioer/dataos-client": ["packages/dataos-client/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist"
  }
}
