{
  "name": "@patioer/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/sensible": "latest",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@patioer/agent-runtime": "workspace:*",
    "@patioer/db": "workspace:*",
    "@patioer/harness": "workspace:*",
    "@patioer/shared": "workspace:*",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "fastify": "latest",
    "fastify-plugin": "^5.1.0",
    "zod": "latest"
  },
  "devDependencies": {
    "tsx": "latest"
  }
}
