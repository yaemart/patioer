{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "ElectroOS — 9 Agent Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Healthy Agents",
      "type": "stat",
      "targets": [{ "expr": "count(electroos_agent_heartbeat_healthy == 1)", "legendFormat": "healthy" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 5 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Pending Approvals",
      "type": "stat",
      "targets": [{ "expr": "sum(electroos_pending_approvals_total)", "legendFormat": "pending" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 35 }, { "color": "red", "value": 45 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Monthly Budget Used (avg)",
      "type": "stat",
      "targets": [{ "expr": "avg(electroos_monthly_budget_used_usd)", "legendFormat": "budget" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Avg Heartbeat Duration",
      "type": "stat",
      "targets": [{ "expr": "avg(electroos_heartbeat_duration_ms)", "legendFormat": "avg_ms" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "title": "Agent Heartbeat Timeline",
      "type": "timeseries",
      "targets": [{ "expr": "electroos_agent_heartbeat_healthy", "legendFormat": "{{agent_type}}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 10,
      "title": "DevOS — Autonomous Loop Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 14 },
      "id": 11,
      "title": "Active Loop Tasks",
      "type": "stat",
      "targets": [{ "expr": "devos_loop_tasks_active", "legendFormat": "active" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 14 },
      "id": 12,
      "title": "Pending Deployments",
      "type": "stat",
      "targets": [{ "expr": "devos_pending_deployments_total", "legendFormat": "pending" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 14 },
      "id": 13,
      "title": "DevOS Agent Count",
      "type": "stat",
      "targets": [{ "expr": "devos_total_agents", "legendFormat": "agents" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 14,
      "title": "Loop Task Completion Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(devos_loop_tasks_completed_total[5m])", "legendFormat": "completed/s" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 20,
      "title": "DataOS — Event Lake / Feature Store / Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 800 }, { "color": "red", "value": 1000 }] }
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 27 },
      "id": 21,
      "title": "Event Lake Write Rate (/s)",
      "type": "stat",
      "targets": [{ "expr": "rate(dataos_event_lake_writes_total[5m])", "legendFormat": "writes/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 27 },
      "id": 22,
      "title": "Feature Store Updated At",
      "type": "stat",
      "targets": [{ "expr": "dataos_feature_store_last_update_timestamp", "legendFormat": "last_update" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 27 },
      "id": 23,
      "title": "Decision Memory Records",
      "type": "stat",
      "targets": [{ "expr": "dataos_decision_memory_total", "legendFormat": "records" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 31 },
      "id": 24,
      "title": "Event Lake Write Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(dataos_event_lake_write_duration_ms_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(dataos_event_lake_write_duration_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(dataos_event_lake_write_duration_ms_bucket[5m]))", "legendFormat": "p99" }
      ]
    }
  ],
  "schemaVersion": 39,
