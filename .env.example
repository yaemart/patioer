DATABASE_URL=postgres://postgres:postgres@localhost:5432/patioer
PORT=3100
PAPERCLIP_API_URL=http://localhost:3000
PAPERCLIP_API_KEY=dev-key
# Optional second secret for POST /api/v1/agents/:id/execute (tenant automation / MCP).
# Same header x-api-key; rotate independently from PAPERCLIP_API_KEY.
# Generate: openssl rand -hex 32
# ELECTROOS_EXECUTE_API_KEY=

# Set to 0 to disable in-process BullMQ workers (e.g. tests or split worker process).
# ENABLE_QUEUE_WORKERS=1

REDIS_URL=redis://localhost:6379
PAPERCLIP_TIMEOUT_MS=5000
PAPERCLIP_MAX_RETRIES=2
PAPERCLIP_RETRY_BASE_MS=200
# Optional local override for Day5 budget gate testing.
AGENT_BUDGET_FORCE_EXCEEDED=0
# Optional compatibility switch. Default is fail-closed (0).
AGENT_BUDGET_FAIL_OPEN=0
# Inventory Guard (Sprint 4 Day 6): default IANA zone when `goalContext.timeZone` is unset and `enforceDailyWindow` is used.
# INVENTORY_GUARD_TZ=UTC
# Sprint 4 Day 8 — POST /api/v1/onboarding/register (x-onboarding-key header)
# ONBOARDING_REGISTER_API_KEY=replace-with-strong-random-key
TENANT_DISCOVERY_API_KEY=replace-with-strong-random-key
TENANT_DISCOVERY_RATE_LIMIT_MAX=60
TENANT_DISCOVERY_RATE_LIMIT_WINDOW_MS=60000

# Shopify OAuth (obtain from Shopify Partners Dashboard)
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
# 32-byte key as 64-char hex — generate with: openssl rand -hex 32
SHOPIFY_ENCRYPTION_KEY=replace-with-64-char-hex-string
# Shopify webhook signing secret (Partners Dashboard → Webhooks)
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
# Public base URL used to build the OAuth callback redirect URI
APP_BASE_URL=https://api.yourdomain.com

# Amazon SP-API OAuth (obtain from Seller Central → Developer Console)
AMAZON_CLIENT_ID=your-amazon-client-id
AMAZON_CLIENT_SECRET=your-amazon-client-secret
# Dedicated CSRF signing key for Amazon OAuth state parameter.
# Decoupled from AMAZON_CLIENT_SECRET so it can be rotated independently.
# Generate: openssl rand -hex 32
AMAZON_STATE_SECRET=replace-with-64-char-hex-string

# Amazon SP-API runtime credentials (used by AmazonHarness at execution time)
AMAZON_REFRESH_TOKEN=your-amazon-refresh-token
AMAZON_SELLER_ID=your-amazon-seller-id
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_REGION=na
# Set to false to use real SP-API production endpoints; true (default) = sandbox
AMAZON_USE_SANDBOX=true

# 32-byte key as 64-char hex for encrypted credential storage (all platforms).
# Replaces SHOPIFY_ENCRYPTION_KEY; SHOPIFY_ENCRYPTION_KEY accepted as fallback.
# Generate: openssl rand -hex 32
CRED_ENCRYPTION_KEY=replace-with-64-char-hex-string

# Shopee Open Platform (partner console + OAuth / webhooks)
SHOPEE_PARTNER_ID=your-shopee-partner-id
SHOPEE_PARTNER_KEY=your-shopee-partner-key

# TikTok Shop (Partner Center — app key/secret; secret also used for API signing & webhooks)
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=your-tiktok-app-secret
TIKTOK_STATE_SECRET=optional-csrf-signing-key-for-oauth-state

# Walmart Marketplace (Client Credentials — obtain from Walmart Developer Center)
WALMART_CLIENT_ID=your-walmart-client-id
WALMART_CLIENT_SECRET=your-walmart-client-secret
WALMART_REGION=us
# Set to false for production Walmart Marketplace API; true (default) = sandbox
WALMART_USE_SANDBOX=true
# Dedicated CSRF signing key for Walmart onboarding state parameter.
# Generate: openssl rand -hex 32
WALMART_STATE_SECRET=replace-with-64-char-hex-string

# Wayfair B2B (not OAuth — supplier credentials registered via POST /api/v1/b2b/wayfair/credentials)
# No env vars required for Wayfair; credentials are per-tenant and stored encrypted in platform_credentials.
# The following are only used if you want a global fallback for internal scripts:
# WAYFAIR_API_BASE_URL=https://api.wayfair.example.com
# WAYFAIR_API_KEY=your-wayfair-api-key
# WAYFAIR_SUPPLIER_ID=your-wayfair-supplier-id

# Market Package — currency conversion (Frankfurter, no API key required)
EXCHANGE_RATE_API_URL=https://api.frankfurter.app
EXCHANGE_RATE_CACHE_TTL_SECONDS=3600

# Prometheus metrics scrape endpoint (/metrics).
# When set, the endpoint requires "Authorization: Bearer <value>" header.
# Leave empty to allow unauthenticated access (only safe on internal networks).
# Generate: openssl rand -hex 32
METRICS_SCRAPE_SECRET=

# Sprint 5 Day 1 — DevOS Paperclip 桥（独立 compose：`docker-compose.devos.yml`，宿主机 3200）
# DEVOS_BASE_URL=http://localhost:3200
# DEVOS_API_KEY=

# Sprint 5 Day 3 — DevOS Postgres 直连 URL（5.10 与 DATABASE_URL 隔离校验）；与 compose 宿主机 5433、库 devos 对齐
# DEVOS_DATABASE_URL=postgres://postgres:postgres@localhost:5433/devos
