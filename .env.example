DATABASE_URL=postgres://postgres:postgres@localhost:5432/patioer
PORT=3100
PAPERCLIP_API_URL=http://localhost:3000
PAPERCLIP_API_KEY=dev-key
TENANT_DISCOVERY_API_KEY=replace-with-strong-random-key
TENANT_DISCOVERY_RATE_LIMIT_MAX=60
TENANT_DISCOVERY_RATE_LIMIT_WINDOW_MS=60000

# Shopify OAuth (obtain from Shopify Partners Dashboard)
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
# 32-byte key as 64-char hex — generate with: openssl rand -hex 32
SHOPIFY_ENCRYPTION_KEY=replace-with-64-char-hex-string
# Shopify webhook signing secret (Partners Dashboard → Webhooks)
SHOPIFY_WEBHOOK_SECRET=your-shopify-webhook-secret
# Public base URL used to build the OAuth callback redirect URI
APP_BASE_URL=https://api.yourdomain.com
